# Agent Daemon Configuration
# 
# This file documents all environment variables used by the agent daemon.
# Copy to .env and customize for your deployment environment.
#

# Node Identity
# Unique identifier for this agent in the cluster.
# Used in heartbeats, logs, and orchestrator scheduling.
NODE_ID=local-node-1

# HTTP Binding Address
# Address and port where the agent HTTP API listens.
# Format: <ip>:<port>
# Examples:
#   127.0.0.1:8090    - Localhost only (development)
#   0.0.0.0:8090      - All interfaces (production)
AGENT_BIND_ADDR=0.0.0.0:8090

# Orchestrator Base URL
# HTTP(S) endpoint where the orchestrator is reachable.
# Daemon sends heartbeats and status updates to this address.
# Format: http[s]://<host>:<port>
ORCHESTRATOR_BASE_URL=http://orchestrator.local:8080

# Heartbeat Interval (seconds)
# How often to send liveness reports to the orchestrator.
# Shorter intervals = faster failure detection, higher overhead.
# Recommended: 30-120 seconds
HEARTBEAT_INTERVAL_SECS=60

# Metrics Poll Interval (seconds)
# How often to sample CPU, RAM, and disk metrics from sysinfo.
# Shorter intervals = more responsive idle detection, higher CPU overhead.
# Recommended: 10-60 seconds
METRICS_POLL_INTERVAL_SECS=30

# Idle CPU Threshold (percentage)
# CPU usage below this threshold = machine is considered idle.
# Sliding window average is compared against this threshold.
# 0-100. Recommended: 5-20%
IDLE_CPU_THRESHOLD_PCT=15.0

# Preempt CPU Threshold (percentage)
# High CPU spike threshold for preemption detection.
# When CPU exceeds this value consecutively, triggers preemption mode
# to gracefully stop workloads before total system overload.
# 0-100. Recommended: 60-90%
PREEMPT_CPU_THRESHOLD_PCT=60.0

# Idle Window Samples
# Size of the sliding window for CPU averaging (number of samples).
# Larger window = smoother idle transitions, less responsive.
# Smaller window = more responsive, noisier.
# Recommended: 5-20
IDLE_WINDOW_SAMPLES=10

# Request Timeout (seconds)
# Timeout for HTTP requests to orchestrator.
# Includes connection timeout and read/write timeouts.
# Recommended: 10-60 seconds. Must be < heartbeat interval.
REQUEST_TIMEOUT_SECS=30

# Docker Configuration (optional, auto-detected)
# If not set, daemon attempts to connect to default Docker socket:
#   Unix: /var/run/docker.sock
#   Windows: \\.\pipe\docker_engine
# For remote Docker daemon, set:
DOCKER_HOST=

# Logging Level (optional)
# Not currently implemented, but reserved for future use.
# Expected values: error, warn, info, debug, trace
RUST_LOG=info

# TLS Configuration (optional, future)
# When mTLS is implemented, these would configure client certificates:
# TLS_CERT_PATH=/etc/agent/certs/client.pem
# TLS_KEY_PATH=/etc/agent/certs/client-key.pem
# TLS_CA_PATH=/etc/agent/certs/ca.pem

# Resource Limits for Spawned Containers (optional, future)
# These would set default limits when /run endpoint doesn't specify:
# DEFAULT_CPU_LIMIT_NCPUS=2
# DEFAULT_MEMORY_LIMIT_MB=1024
# DEFAULT_STORAGE_LIMIT_GB=10
